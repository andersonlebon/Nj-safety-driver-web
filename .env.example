# Supabase configuration
# Find these values in your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: only used by privileged server-side admin utilities (NOT exposed to client)
# Service role key has full access. Keep it secret!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for auth redirects). For local dev use http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Direct Postgres connection string — used ONLY by `npm run db:push` and
# `npm run db:studio` to sync schema + RLS to your Supabase database.
# Find it at: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "URI" version and replace [YOUR-PASSWORD] with your DB password.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres
