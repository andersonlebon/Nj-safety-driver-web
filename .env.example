# Supabase configuration
# Find these values in your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: only used by privileged server-side admin utilities (NOT exposed to client)
# Service role key has full access. Keep it secret!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for auth redirects). For local dev use http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
