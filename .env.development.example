# =====================================================================
# Development environment template
# =====================================================================
# Copy this file to `.env.local` and point it at your DEV Supabase project.
# (Keep `.env.local` git-ignored — never commit real keys.)
#
# Recommended: create a SEPARATE Supabase project for development so that
# experimental migrations or test data never touch production records.
# =====================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-DEV-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-DEV-anon-key

# Optional: only used by privileged server-side admin utilities.
# NEVER expose this to the client. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-DEV-service-role-key

# Local dev URL used by Supabase auth redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Helpful for local debugging
NODE_ENV=development
